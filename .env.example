# ──────────────────────────────────────────────
# Mi Estampa — variables de entorno
# Copiar a .env.local y llenar
# NUNCA commitear .env.local
# ──────────────────────────────────────────────

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SOLO server-side. NUNCA prefijo NEXT_PUBLIC_. Bypassa RLS.
SUPABASE_SERVICE_ROLE_KEY=

# Connection string Postgres (Project Settings → Database → Connection string → URI)
# Usado por los scripts scripts/db-apply.mjs y scripts/db-seed.mjs
SUPABASE_DB_URL=

# Resend (sección 08 — notificación por correo a las socias)
RESEND_API_KEY=
# Correos de las socias separados por coma
NOTIFY_EMAIL_TO=

# WhatsApp (sección 08 — v1 usa wa.me / click-to-chat, sin API formal)
# Números de las socias separados por coma. Formato internacional sin +, ej: 59171234567,59172345678
NOTIFY_WHATSAPP_NUMBERS=

# Pago QR (sección 07 — datos bancarios y QR reales, pendientes del cliente)
NEXT_PUBLIC_BANK_NAME=
NEXT_PUBLIC_BANK_HOLDER=
# Si se deja vacío, se usa un QR de ejemplo subido en Storage (bucket payment-qr)
NEXT_PUBLIC_PAYMENT_QR_URL=

# Branding / app
NEXT_PUBLIC_APP_URL=http://localhost:3000
